<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bsi_bank_account_transactions_list_view" model="ir.ui.view">
        <field name="name">bai.bank.account.transaction.list</field>
        <field name="model">bai.bank.account.transactions</field>
        <field name="arch" type="xml">
            <list>
                <!-- <header>
                    <button string="Fetch Data" name="sftp_connection" type="object" class="oe_highlight" display="always"/>
                </header> -->

                <field name="type_code"/>
                <field name="transaction_type"/>
                <field name="transaction_date"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="bsi_bank_account_transactions_form_view" model="ir.ui.view">
        <field name="name">bai.bank.account.transaction.form</field>
        <field name="model">bai.bank.account.transactions</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Account Transactions">
                        <field name="type_code"/>
                        <field name="transaction_type"/>
                        <field name="transaction_date"/>
                        <field name="amount"/>
                        <field name="account_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="bsi_bank_account_transactions_action" model="ir.actions.act_window">
        <field name="name">Bank Account Transactions</field>
        <field name="res_model">bai.bank.account.transactions</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_bsi_bank_account_transactions"
        name="Bank Account Transaction"
        parent="bsi_bank_statement_root_menu"
        action="bsi_bank_account_transactions_action" sequence="2"/>
    

</odoo>
