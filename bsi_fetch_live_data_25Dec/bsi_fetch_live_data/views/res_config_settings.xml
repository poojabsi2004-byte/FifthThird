<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Ticket_res_config_settings_view_form-->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.fetch.live.data
        </field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="15"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                 <app data-string="Fetch Live Data" string="Fetch Live Data" name="fetch_live_data" >
              <!--   <div class="app_settings_block" data-string="Fetch Live Data"
                     string="Fetch Live Data" data-key="bsi_fetch_live_data"> -->
                     <h2>Live Data Keys</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-lg-6 o_setting_box">
                            <h4>Account 2</h4>
                             <div class="o_setting_right_pane">
                                <label for="account_two_api_key" string="API Key"/>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="account_two_api_key"/>
                                    </div>
                                </div>
                                 <label for="account_two_api_client" string="Client Key"/>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="account_two_api_client"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 o_setting_box">
                            <h4>Account 3</h4>
                             <div class="o_setting_right_pane">
                                <label for="account_three_api_key" string="API Key"/>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="account_three_api_key"/>
                                    </div>
                                </div>
                                 <label for="account_three_api_client" string="Client Key"/>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="account_three_api_client"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 o_setting_box">
                             <div class="o_setting_right_pane">
                                <label for="day_distance" string="Days Difference"/>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="day_distance"/>
                                    </div>
                                </div>
                                 
                            </div>
                        </div>
                    </div>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
